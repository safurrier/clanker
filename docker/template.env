# Development environment variables
PYTHON_ENV=development

# Clanker9000 Bot Configuration
APP_NAME=clanker9000
DEBUG=true

# Required Secrets (do not commit actual values)
DISCORD_TOKEN=your_discord_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional Secrets
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Configuration
# Only set if using non default
#CLANKER_CONFIG_PATH=/workspace/config.yaml

# Container runtime settings (optional)
# UID=${UID}  # Uncomment to use your system UID
# GID=${GID}  # Uncomment to use your system GID
# DOCKER_SOCK=/var/run/docker.sock  # Override socket path for Podman
